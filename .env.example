# Purpose of this file:
# - This is a template for local .env.local values.
# - Do not commit real secret values.
# - Copy these keys to your local .env.local and fill values there.
#
# Scope model used in this repo:
# - local-only: use in local .env.local only (never in App Hosting config)
# - apphosting-non-secret: keep in apps/web/apphosting.yaml for deployed config
# - secret-manager: store in Cloud Secret Manager and reference from apphosting.yaml
# - system-managed: injected by App Hosting/Cloud Run; do not set manually
#
# Required/optional labels below mean:
# - required: needed for the related feature to work
# - optional: safe to leave blank when that feature/path is not used
#
# App Hosting reserved-name safety when promoting keys from this template:
# - Do not use keys that begin with X_FIREBASE_, X_GOOGLE_, CLOUD_RUN_
# - Do not define PORT, K_SERVICE, K_REVISION, or K_CONFIGURATION
#
# Variable precedence on App Hosting:
# firebase console > apphosting.<env>.yaml > apphosting.yaml > Firebase system vars

# Platform runtime hints.
# scope: system-managed in hosted environments; keep optional local placeholders for compatibility.
# optional: local placeholders only; do not set manually in App Hosting
VERCEL_URL=
__FIREBASE_FRAMEWORKS_ENTRY__=next.js
# Firebase frameworks metadata payload used by some hosted runtimes during bootstrap.
# Keep as a JSON string value in one line.
__FIREBASE_DEFAULTS__={"config":{"projectId":"zootopia2026","appId":"1:38079185268:web:adcd16b5e94d3d8c52ec21","storageBucket":"zootopia2026.firebasestorage.app","apiKey":"yY","authDomain":"zootopia2026.firebaseapp.com","messagingSenderId":"38079185268","projectNumber":"38079185268","version":"2"},"_authTokenSyncURL":"/__session"}
# FIREBASE_WEBAPP_CONFIG= (system-managed on App Hosting build; do not set manually)

# Public browser-safe Firebase config.
# scope: local .env.local + apphosting-non-secret (BUILD)
# required: required for Firebase web SDK initialization
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyC6hGFAPdpN9jAEH39D5lvnadw9JJX3qyY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zootopia2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zootopia2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zootopia2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=38079185268
NEXT_PUBLIC_FIREBASE_APP_ID=1:38079185268:web:adcd16b5e94d3d8c52ec21

# Private Firebase server config.
# scope: local .env.local + apphosting-non-secret (runtime), unless noted
# required: FIREBASE_PROJECT_ID and FIREBASE_STORAGE_BUCKET are required
# required: FIREBASE_CLIENT_EMAIL + FIREBASE_PRIVATE_KEY only when managed runtime identity is unavailable
FIREBASE_PROJECT_ID=zootopia2026
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@zootopia2026.iam.gserviceaccount.com
# Keep multiline private key only in local .env.local or secret manager.
# If you set this directly in .env.local, use one quoted line with escaped newlines:
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=zootopia2026.firebasestorage.app
ZOOTOPIA_ADMIN_EMAILS=alahlyeagle@gmail.com,elmahdy@admin.com,alahlyeagle13@gmail.com

# Optional service-account fallback values.
# scope: local .env.local + secret-manager (runtime)
# Leave blank when relying on managed runtime identity in App Hosting.
# optional: fallback only
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=

# Legacy fallback aliases accepted by runtime/scripts.
# scope: local .env.local only (prefer canonical FIREBASE_* keys above)
# Prefer canonical FIREBASE_* keys above for new setups.
# optional: compatibility only
FIREBASE_ADMIN_PROJECT_ID=zootopia2026
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk-fbsvc@zootopia2026.iam.gserviceaccount.com
# Keep blank unless a legacy script still reads this alias.
FIREBASE_ADMIN_PRIVATE_KEY=

# Session and maintenance controls.
# scope: local .env.local + apphosting-non-secret (runtime) unless noted
# optional: ZOOTOPIA_SESSION_TTL_SECONDS (default applies when blank)
# optional: ZOOTOPIA_MAINTENANCE_SECRET, required only when internal scheduler endpoint is enabled
ZOOTOPIA_SESSION_TTL_SECONDS=3600
# Default successful assessment credits per UTC day for regular users.
# fallback: 3 when this value is blank/invalid; admins remain exempt.
ZOOTOPIA_DEFAULT_DAILY_ASSESSMENT_CREDITS=3
# Optional legacy alias read by the same server parser.
DEFAULT_DAILY_ASSESSMENT_CREDITS=
# scope: secret-manager (runtime) if scheduler endpoint is enabled
ZOOTOPIA_MAINTENANCE_SECRET=

# Contact relay non-secrets.
# scope: local .env.local + apphosting-non-secret (runtime)
# required: required only when /api/contact is enabled
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Contact relay secrets.
# scope: local .env.local + secret-manager (runtime)
# required: required only when /api/contact is enabled
SMTP_USER=alahlyeagle13@gmail.com
SMTP_PASS=
EMAIL_FROM=Zootopia Club <alahlyeagle13@gmail.com>
CONTACT_FORM_TO=alahlyeagle13@gmail.com

# AI provider secrets.
# scope: local .env.local + secret-manager (runtime)
# required: at least one provider key is required (GOOGLE_AI_API_KEY or DASHSCOPE_API_KEY)
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=

# AI non-secret runtime tuning.
# scope: local .env.local + apphosting-non-secret (runtime)
# optional: defaults are used when blank
# Keep DashScope on US (Virginia) when used.
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
DASHSCOPE_COMPATIBLE_BASE_URL=
ALIBABA_MODEL_STUDIO_BASE_URL=

# Optional model overrides.
# scope: local .env.local + apphosting-non-secret (runtime)
# optional: leave blank to keep catalog defaults
GOOGLE_AI_MODEL=
GOOGLE_AI_ADVANCED_MODEL=
QWEN_MODEL=

# Pro PDF local executable overrides.
# scope: local-only (development machine only)
# optional: only for local PDF lane troubleshooting
ASSESSMENT_PDF_BROWSER_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=

# Admin password handling (command only).
# Never store this in any .env file or source-controlled config.
# Use shell-only for one command invocation:
# ZOOTOPIA_ADMIN_PASSWORD=... npm run firebase:admin:set-passwords
