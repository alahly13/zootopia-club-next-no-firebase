# Root .env.local is the canonical env source for both:
# - root Firebase maintenance scripts
# - the live Next.js app in apps/web (loaded through @next/env in next.config.ts)
#
# Public Firebase web config (safe for browser)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyC6hGFAPdpN9jAEH39D5lvnadw9JJX3qyY
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=zootopia2026.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=zootopia2026
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=zootopia2026.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=38079185268
NEXT_PUBLIC_FIREBASE_APP_ID=1:38079185268:web:adcd16b5e94d3d8c52ec21

# Private Firebase Admin config (server only)
FIREBASE_PROJECT_ID=zootopia2026
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=zootopia2026.firebasestorage.app
ZOOTOPIA_ADMIN_EMAILS=alahlyeagle@gmail.com,elmahdy@admin.com,alahlyeagle13@gmail.com
# Legacy fallback aliases still accepted by runtime/scripts (optional).
# Prefer the canonical FIREBASE_* keys above for new setups.
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Session and maintenance lifecycle controls (server only)
# Session lifetime is in seconds and defaults to 3600 when omitted.
ZOOTOPIA_SESSION_TTL_SECONDS=3600
# Optional: set this secret to allow scheduler-triggered expired upload cleanup.
ZOOTOPIA_MAINTENANCE_SECRET=

# Private contact form SMTP relay (server only)
# Keep these values in local/server env or Firebase App Hosting runtime env.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
CONTACT_FORM_TO=

# Private AI provider config (server only)
GOOGLE_AI_API_KEY=
DASHSCOPE_API_KEY=
# Keep DashScope on the US (Virginia) compatible-mode runtime for this project.
# The API key must match the same region endpoint.
DASHSCOPE_BASE_URL=https://dashscope-us.aliyuncs.com/compatible-mode/v1
# Optional compatibility aliases accepted by provider runtime.
DASHSCOPE_COMPATIBLE_BASE_URL=
ALIBABA_MODEL_STUDIO_BASE_URL=

# Optional model override env keys used by the shared model catalog.
GOOGLE_AI_MODEL=
GOOGLE_AI_ADVANCED_MODEL=
QWEN_MODEL=

# Optional local Pro PDF executable overrides (development only).
ASSESSMENT_PDF_BROWSER_EXECUTABLE_PATH=
PUPPETEER_EXECUTABLE_PATH=

# Admin password handling
# Never store the shared admin password in .env files, Firestore, rules, or client code.
# If needed for one command, set ZOOTOPIA_ADMIN_PASSWORD only in your shell session.
# Set or rotate Firebase Auth passwords with:
# npm run firebase:admin:set-passwords -- --password "replace-me"
