{
  "firestore": [
    {
      "database": "zootopia-club-next-database",
      "rules": "firebase/firestore.rules",
      "indexes": "firebase/firestore.indexes.json"
    }
  ],
  "storage": {
    "rules": "firebase/storage.rules"
  },
  "apphosting": {
    "backendId": "zootopia-club-next-backend",
    "rootDir": "./apps/web",
    "ignore": [
      "node_modules",
      ".next",
      "output",
      ".history",
      ".tmp",
      "tsconfig.tsbuildinfo",
      ".git",
      "firebase-debug.log",
      "firebase-debug.*.log",
      "functions"
    ]
  }
}
